generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  staff
  supplier
  trial
}

enum PlanType {
  free
  starter
  growth
  pro
  custom
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  expired
  trialing
}

enum WorkspaceStatus {
  active
  suspended
  trial
}

enum StockMovementType {
  in
  out
  transfer
}

enum SyncStatus {
  pending
  syncing
  synced
  failed
  needs_review
}

model User {
  id             String             @id @default(cuid())
  name           String
  email          String             @unique
  passwordHash   String
  role           UserRole           @default(admin)
  avatar         String?
  disabledAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    WorkspaceMember[]
  movements      StockMovement[]
  auditLogs      AuditLog[]
  syncOperations SyncOperation[]
  scheduledActivities ScheduledActivity[]
}

model Workspace {
  id             String             @id @default(cuid())
  name           String
  plan           PlanType           @default(free)
  status         WorkspaceStatus    @default(active)
  logo           String?
  trialEndsAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  members        WorkspaceMember[]
  subscriptions  Subscription[]
  entitlements   Entitlement[]
  categories     Category[]
  products       Product[]
  warehouses     Warehouse[]
  inventoryItems InventoryItem[]
  movements      StockMovement[]
  suppliers      Supplier[]
  auditLogs      AuditLog[]
  syncOperations SyncOperation[]
  settings       SystemSetting[]
  scheduledActivities ScheduledActivity[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole  @default(admin)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Subscription {
  id                 String             @id @default(cuid())
  workspaceId        String
  plan               PlanType
  status             SubscriptionStatus @default(active)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model Entitlement {
  id          String    @id @default(cuid())
  workspaceId String
  feature     String
  enabled     Boolean   @default(true)
  limit       Int?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, feature])
}

model Category {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([workspaceId, name])
}

model Product {
  id             String           @id @default(cuid())
  workspaceId    String
  sku            String
  name           String
  description    String?
  categoryId     String
  minStock       Int              @default(0)
  price          Int              @default(0)
  disabledAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category       Category         @relation(fields: [categoryId], references: [id])
  inventoryItems InventoryItem[]
  movements      StockMovement[]

  @@unique([workspaceId, sku])
  @@index([workspaceId, categoryId])
}

model Warehouse {
  id                   String           @id @default(cuid())
  workspaceId          String
  name                 String
  address              String?
  isDefault            Boolean          @default(false)
  disabledAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  workspace            Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inventoryItems       InventoryItem[]
  movements            StockMovement[]  @relation("MovementWarehouse")
  destinationMovements StockMovement[]  @relation("DestinationWarehouse")

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model InventoryItem {
  id          String    @id @default(cuid())
  workspaceId String
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([workspaceId, warehouseId])
}

model StockMovement {
  id            String            @id @default(cuid())
  workspaceId   String
  productId     String
  warehouseId   String
  toWarehouseId String?
  type          StockMovementType
  quantity      Int
  notes         String?
  userId        String
  createdAt     DateTime          @default(now())
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id])
  warehouse     Warehouse         @relation("MovementWarehouse", fields: [warehouseId], references: [id])
  toWarehouse   Warehouse?        @relation("DestinationWarehouse", fields: [toWarehouseId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([productId])
  @@index([warehouseId])
}

model Supplier {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  disabledAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

model SyncOperation {
  id            String     @id @default(cuid())
  workspaceId   String
  userId        String
  key           String
  operationType String
  status        SyncStatus @default(pending)
  payload       Json?
  response      Json?
  error         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId, status])
}

model ScheduledActivity {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  type        String
  status      String    @default("pending")
  description String?
  dueAt       DateTime?
  disabledAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, dueAt])
}

model SystemSetting {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  value       String
  description String?
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
}
